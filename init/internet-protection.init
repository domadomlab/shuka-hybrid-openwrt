#!/bin/sh /etc/rc.common

# Init script for Internet Protection Watchdog
START=99
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /bin/sh /usr/bin/internet-protection.sh
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    killall internet-protection.sh
}
